{
    "name": "kilden/kilden-wp",
    "description": "Kilden analytics for WordPress and WooCommerce (development manifest; the plugin ships with the core vendored)",
    "license": "GPL-2.0-or-later",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "kilden/kilden-php": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../kilden-sdk-php",
            "options": {
                "symlink": true
            }
        }
    ],
    "scripts": {
        "vendor-core": "php bin/build-vendor.php",
        "test": "phpunit",
        "stan": "phpstan analyse --no-progress"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
